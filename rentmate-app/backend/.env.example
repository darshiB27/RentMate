# Server Configurations
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (Replace with your own connection string)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/rentmate?retryWrites=true&w=majority

# JWT Configurations
JWT_ACCESS_SECRET=your_jwt_access_secret_string_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_string_here
JWT_REFRESH_EXPIRY=7d

# Cloudinary Credentials (Replace with actual credentials)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Mail Configurations (Replace with actual credentials)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="RentMate Support" <noreply@rentmate.com>

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback